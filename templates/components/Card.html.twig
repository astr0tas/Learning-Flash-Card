{#
Please follow the rule bellow to ensure there will be no bugs and errors:
 - There should be only one component instance for createMode, editMode and viewMode properties. The listMode property can have multiple instances
 - allowEdit property belong to viewMode
#}

{% set new_card_title = error.newCardTitle|default('') %}
{% set new_card_subtitle = error.newCardSubtitle|default('') %}
{% set new_card_description = error.newCardDescription|default('') %}
{% set new_card_type = error.newCardType|default('') %}
{% set new_card_color = error.newCardColor|default(constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR')) %}
{% set new_card_text_color = error.newCardTextColor|default(constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR')) %}

{% set edit_card_id = error.editCardId|default(null) %}
{% set edit_card_title = error.editCardTitle|default('') %}
{% set edit_card_subtitle = error.editCardSubtitle|default('') %}
{% set edit_card_description = error.editCardDescription|default('') %}
{% set edit_card_type = error.editCardType|default('') %}
{% set edit_card_color = error.editCardColor|default(constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR')) %}
{% set edit_card_text_color = error.editCardTextColor|default(constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR')) %}

{% if createMode %}
  <div class="flex flex-col gap-5 z-50 w-full h-full" x-data="{ title: {{ new_card_title|json_encode }}, subtitle: {{ new_card_subtitle|json_encode }}, description: {{ new_card_description|json_encode }}, cardColor: '{{ new_card_color }}', textColor: '{{ new_card_text_color }}' }"
  x-init="$nextTick(() => {
    // Trigger change event in the case of new card creation validation error to update the select display div with the correct selected option text
    document.getElementById('card_type').dispatchEvent(new CustomEvent('set', { detail: '{{ new_card_type }}' }));
  })"
  @reset-new-card-inputs.window="document.getElementById('div_new_card_title').innerText = ''; title = '';
  document.getElementById('div_new_card_subtitle').innerText = ''; subtitle = '';
  document.getElementById('div_new_card_description').innerHTML = ''; description = '';
  document.getElementById('card_type').dispatchEvent(new Event('reset'));
  document.getElementById('card_color').dispatchEvent(new Event('reset'));
  document.getElementById('card_text_color').dispatchEvent(new Event('reset'));
  document.getElementById('new_card_title_error')?.remove();
  document.getElementById('new_card_subtitle_error')?.remove();
  document.getElementById('new_card_description_error')?.remove();">
    <div class="w-full h-full flex flex-col gap-5 relative rounded-md py-10 px-3" x-bind:style="{ backgroundColor: cardColor, color: textColor }">
      {% if bagId is defined and bagId %}
        <input hidden name="bag" value="{{ bagId }}"/>
      {% endif %}
      <input hidden name="title" :value="title">
      <input hidden name="subtitle" :value="subtitle">
      <input hidden name="description" :value="description">
      <div class="flex flex-col gap-3 text-center">
        <h2 class="text-5xl" id="div_new_card_title" contenteditable @paste.prevent="document.execCommand('insertText', false, $event.clipboardData.getData('text/plain'))" @input="title = $el.innerText" data-placeholder="{{ 'card_bag.card_title'|trans }}">{{ new_card_title }}</h2>
        {% if error.newCardError is defined and error.newCardError.title is defined %}
          <div id="new_card_title_error" class="mt-1 text-xs text-(--red)">
            {{ error.newCardError.title[0] }}
          </div>
        {% endif %}
      </div>
      <div class="flex flex-col gap-3 text-center">
        <h5 class="text-xl" id="div_new_card_subtitle" contenteditable @paste.prevent="document.execCommand('insertText', false, $event.clipboardData.getData('text/plain'))" @input="subtitle = $el.innerText" data-placeholder="{{ 'card_bag.card_subtitle'|trans }}">{{ new_card_subtitle }}</h5>
        {% if error.newCardError is defined and error.newCardError.subtitle is defined %}
          <div id="new_card_subtitle_error" class="mt-1 text-xs text-(--red)">
            {{ error.newCardError.subtitle[0] }}
          </div>
        {% endif %}
      </div>
      <div class="flex flex-col gap-3 text-start">
        <div class="flex-1 whitespace-pre-line text-md overflow-auto scroll-container" id="div_new_card_description" contenteditable @paste.prevent="document.execCommand('insertText', false, $event.clipboardData.getData('text/plain'))" @input="description = $el.innerHTML" data-placeholder="{{ 'card_bag.card_description'|trans }}">{{ new_card_description|raw }}</div>
        {% if error.newCardError is defined and error.newCardError.description is defined %}
          <div id="new_card_description_error" class="mt-1 text-xs text-(--red)">
            {{ error.newCardError.description[0] }}
          </div>
        {% endif %}
      </div>
    </div>
    <div class="flex flex-col gap-5 w-full text-start p-5 rounded-md" :class="darkMode ? 'bg-(--dark-theme-bg-color) text-(--white)' : 'bg-(--white) text-(--black)'">
      <div>
        <twig:Select name="card_type" label="{{ 'card_bag.card_type'|trans }}" aria-label="{{ 'card_bag.card_type'|trans }}" required error="{{ error.newCardError is defined and error.newCardError.card_type is defined ? error.newCardError.card_type[0] : '' }}" defaultValue="">
          <twig:block name="options">
            {% for type in constant('App\\Config\\Constants::FLASH_CARD_BAG_TYPES') %}
              <option value="{{ type }}">{{ ('card_bag.card_type_'~(type|lower))|trans }}</option>
            {% endfor %}
          </twig:block>
        </twig:Select>
      </div>
      <div>
        <twig:Input type="color" name="card_color" label="{{ 'card_bag.card_color'|trans }}" aria-label="{{ 'card_bag.card_color'|trans }}" x-model="cardColor" defaultValue="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}" error="{{ error.newCardError is defined and error.newCardError.card_color is defined ? error.newCardError.card_color[0] : '' }}"/>
      </div>
      <div>
        <twig:Input type="color" name="card_text_color" label="{{ 'card_bag.card_text_color'|trans }}" aria-label="{{ 'card_bag.card_text_color'|trans }}" x-model="textColor" defaultValue="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}" error="{{ error.newCardError is defined and error.newCardError.card_text_color is defined ? error.newCardError.card_text_color[0] : '' }}"/>
      </div>
      <div class="pb-3 pt-2 flex flex-row-reverse gap-3">
        <div class="inline-flex">
          <twig:Button type="button" class="text-sm" variant="primary" title="{{ 'action.add'|trans }}" @click="$dispatch('submit-form')">
            {{ 'action.add'|trans }}
          </twig:Button>
        </div>
        <div class="inline-flex">
          <twig:Button type="button" class="text-sm" variant="outline" title="{{ 'action.cancel'|trans }}" @click="$dispatch('close-create-new-card-modal')">
            {{ 'action.cancel'|trans }}
          </twig:Button>
        </div>
      </div>
    </div>
  </div>
{% elseif editMode %}
  <div class="flex flex-col gap-5 z-50 w-full h-full"
  x-data="{ id: {{ edit_card_id ? edit_card_id : 'null' }}, title: {{ edit_card_title|json_encode }}, subtitle: {{ edit_card_subtitle|json_encode }}, description: {{ edit_card_description|json_encode }}, cardColor: '{{ edit_card_color }}', textColor: '{{ edit_card_text_color }}' }"
  x-init="$nextTick(() => {
    // Trigger change event in the case of edit card validation error to update the select display div with the correct selected option text
    document.getElementById('edit_card_type').dispatchEvent(new CustomEvent('set', { detail: '{{ edit_card_type }}' }));
  })"
  @set-edit-card-inputs.window="id = $event.detail.id ?? null;
  document.getElementById('div_edit_card_title').innerText = title = $event.detail.title ?? ''; title = $event.detail.title ?? '';
  document.getElementById('div_edit_card_subtitle').innerText = subtitle = $event.detail.subtitle ?? ''; subtitle = $event.detail.subtitle ?? null;
  document.getElementById('div_edit_card_description').innerHTML = description = $event.detail.description ?? ''; description = $event.detail.description ?? null;
  document.getElementById('edit_card_type').dispatchEvent(new CustomEvent('set', { detail: $event.detail.type ?? '' }));
  document.getElementById('edit_card_color').dispatchEvent(new CustomEvent('set', { detail: $event.detail.color ?? '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}' })); cardColor = $event.detail.color ?? '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}';
  document.getElementById('edit_card_text_color').dispatchEvent(new CustomEvent('set', { detail: $event.detail.textColor ?? '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}' })); textColor = $event.detail.textColor ?? '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}';
  document.getElementById('edit_card_title_error')?.remove();
  document.getElementById('edit_card_subtitle_error')?.remove();
  document.getElementById('edit_card_description_error')?.remove()">
    <div class="w-full h-full flex flex-col gap-5 relative rounded-md py-10 px-3" x-bind:style="{ backgroundColor: cardColor, color: textColor }">
      <input hidden name="card" :value="id">
      <input hidden name="title" :value="title">
      <input hidden name="subtitle" :value="subtitle">
      <input hidden name="description" :value="description">
      <div class="flex flex-col gap-3 text-center">
        <h2 class="text-5xl" id="div_edit_card_title" contenteditable @paste.prevent="document.execCommand('insertText', false, $event.clipboardData.getData('text/plain'))" @input="title = $el.innerText" data-placeholder="{{ 'card_bag.card_title'|trans }}">{{ edit_card_title }}</h2>
        {% if error.editCardError is defined and error.editCardError.title is defined %}
          <div id="edit_card_title_error" class="mt-1 text-xs text-(--red)">
            {{ error.editCardError.title[0] }}
          </div>
        {% endif %}
      </div>
      <div class="flex flex-col gap-3 text-center">
        <h5 class="text-xl" id="div_edit_card_subtitle" contenteditable @paste.prevent="document.execCommand('insertText', false, $event.clipboardData.getData('text/plain'))" @input="subtitle = $el.innerText" data-placeholder="{{ 'card_bag.card_subtitle'|trans }}">{{ edit_card_subtitle }}</h5>
        {% if error.editCardError is defined and error.editCardError.subtitle is defined %}
          <div id="edit_card_subtitle_error" class="mt-1 text-xs text-(--red)">
            {{ error.editCardError.subtitle[0] }}
          </div>
        {% endif %}
      </div>
      <div class="flex flex-col gap-3 text-start">
        <div class="flex-1 whitespace-pre-line text-md overflow-auto scroll-container" id="div_edit_card_description" contenteditable @paste.prevent="document.execCommand('insertText', false, $event.clipboardData.getData('text/plain'))" @input="description = $el.innerHTML" data-placeholder="{{ 'card_bag.card_description'|trans }}">{{ edit_card_description|raw }}</div>
        {% if error.editCardError is defined and error.editCardError.description is defined %}
          <div id="edit_card_description_error" class="mt-1 text-xs text-(--red)">
            {{ error.editCardError.description[0] }}
          </div>
        {% endif %}
      </div>
    </div>
    <div class="flex flex-col gap-5 w-full text-start p-5 rounded-md" :class="darkMode ? 'bg-(--dark-theme-bg-color) text-(--white)' : 'bg-(--white) text-(--black)'">
      <div>
        <twig:Select name="card_type" id="edit_card_type" label="{{ 'card_bag.card_type'|trans }}" aria-label="{{ 'card_bag.card_type'|trans }}" required error="{{ error.editCardError is defined and error.editCardError.card_type is defined ? error.editCardError.card_type[0] : '' }}" defaultValue="">
          <twig:block name="options">
            {% for type in constant('App\\Config\\Constants::FLASH_CARD_BAG_TYPES') %}
              <option value="{{ type }}">{{ ('card_bag.card_type_'~(type|lower))|trans }}</option>
            {% endfor %}
          </twig:block>
        </twig:Select>
      </div>
      <div>
        <twig:Input type="color" name="card_color" id="edit_card_color" label="{{ 'card_bag.card_color'|trans }}" aria-label="{{ 'card_bag.card_color'|trans }}" x-model="cardColor" defaultValue="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}" error="{{ error.editCardError is defined and error.editCardError.card_color is defined ? error.editCardError.card_color[0] : '' }}"/>
      </div>
      <div>
        <twig:Input type="color" name="card_text_color" id="edit_card_text_color" label="{{ 'card_bag.card_text_color'|trans }}" aria-label="{{ 'card_bag.card_text_color'|trans }}" x-model="textColor" defaultValue="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}" error="{{ error.editCardError is defined and error.editCardError.card_text_color is defined ? error.editCardError.card_text_color[0] : '' }}"/>
      </div>
      <div class="pb-3 pt-2 flex flex-row-reverse gap-3">
        <div class="inline-flex">
          <twig:Button type="button" class="text-sm" variant="primary" title="{{ 'action.edit'|trans }}" @click="$dispatch('submit-form')">
            {{ 'action.edit'|trans }}
          </twig:Button>
        </div>
        <div class="inline-flex">
          <twig:Button type="button" class="text-sm" variant="outline" title="{{ 'action.cancel'|trans }}" @click="$dispatch('close-edit-card-modal')">
            {{ 'action.cancel'|trans }}
          </twig:Button>
        </div>
      </div>
    </div>
  </div>
{% elseif listMode %}
  <div class="w-full h-full flex flex-col gap-3 relative rounded-md cursor-pointer p-5" style="background-color: {{ cardColor }}; color: {{ cardTextColor }};">
    <h2 class="text-3xl text-center">{{ cardTitle }}</h2>
    <h5 class="text-center text-md">{{ cardSubtitle }}</h5>
    <div class="flex-1 text-start whitespace-pre-line text-xs overflow-hidden text-ellipsis break-words line-clamp-11">{{ cardDescription|raw }}</div>
    <div class="absolute right-2 top-2">
      <twig:ClickInput type="checkbox" class="cursor-default!" name="card_{{ cardId }}_checkbox" @click.stop x-model="{{ model is defined ? model : null }}" value="{{ cardId }}" x-bind:style="{borderColor: getContrastColor('{{ cardColor }}')}"></twig:ClickInput>
    </div>
  </div>
{% elseif viewMode %}
  <div x-data="{ id: null, title: '', subtitle: null, description: null, color: '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}', type: '', textColor: '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}' }"
  @set-view-card-data.window="id = $event.detail.id ?? null; title = $event.detail.title ?? ''; subtitle = $event.detail.subtitle ?? null;
  description = $event.detail.description ?? null; color = $event.detail.color ?? '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}';
  type = $event.detail.type ?? ''; textColor = $event.detail.textColor ?? '{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}';"
  class="w-full h-full flex flex-col gap-3 relative rounded-md py-20 px-3" x-bind:style="{ backgroundColor: color, color: textColor }">
    <h2 class="text-5xl text-center" x-text="title"></h2>
    <h5 class="text-center text-xl" x-text="subtitle"></h5>
    <div class="flex-1 text-start whitespace-pre-line text-md overflow-auto scroll-container" x-html="description"></div>
    <div class="absolute right-5 top-5">
      <div class="w-6 h-6 hover:opacity-80 active:opacity-60 cursor-pointer" x-bind:style="{color: getContrastColor(color)}" @click="$dispatch('close-view-card-modal')">
        {{ include('icons/close.svg') }}
      </div>
    </div>
    {% if allowEdit %}
      <div class="absolute left-5 top-5">
        <div class="w-6 h-6 hover:opacity-80 active:opacity-60 cursor-pointer" x-bind:style="{color: getContrastColor(color)}" @click="$dispatch('edit-card', id)">
          {{ include('icons/edit.svg') }}
        </div>
      </div>
    {% endif %}
  </div>
{% endif %}