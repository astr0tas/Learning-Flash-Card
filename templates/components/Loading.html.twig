<div x-data="{ isLoading: false }" x-show="isLoading" class="w-full h-full flex items-center justify-center {{ fullScreenLoading ? 'fixed z-5000' : '' }}" @set-loading.window="isLoading=true" @unset-loading.window="isLoading=false">
  <div class="bg-white/30 backdrop-blur-[2px] w-full h-full"></div>
  <div role="status" class="loader"></div>
</div>
