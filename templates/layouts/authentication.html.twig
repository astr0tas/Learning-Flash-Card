{% extends 'layouts/base.html.twig' %}

{% block stylesheets %}
	<style>
		.light_theme .auth_layout_bg {
			background-color: var(--white);
		}

		.dark_theme .auth_layout_bg {
			background-color: var(--dark-theme-bg-color);
		}
	</style>
{% endblock %}

{% block body %}
	<div class="w-full h-full relative">
		<img src="/images/auth_bg.jpg" alt="Background Image" class="absolute w-full h-full object-cover opacity-85 hidden md:block">
		<img src="/images/auth_bg_mobile.jpg" alt="Background Image" class="absolute w-full h-full object-cover opacity-75 block md:hidden">
		<div class="relative z-10 w-full h-full flex p-[5px]">
			<div class="mx-auto md:ms-20 xl:ms-50 md:me-0 my-auto rounded-lg w-full max-w-[400px] p-3 md:p-5 auth_layout_bg shadow-lg">
				{% block auth_body %}{% endblock %}
			</div>
		</div>
	</div>
{% endblock %}
