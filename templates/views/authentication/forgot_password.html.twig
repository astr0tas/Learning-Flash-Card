{% extends 'layouts/authentication.html.twig' %}
{% block title %}
  {{ 'forgot_password.title'|trans }}
{% endblock %}
{% set email = email | default('') %}
{% set success = success | default(false) %}
{% block auth_body %}
  {% if success %}
    <div class="flex flex-col items-center" data-turbo="false">
      <div class="w-[50px] h-[50px]">
        {{ include('icons/success.svg') }}
      </div>
      <h1 class="font-bold text-[23px] text-center my-3">
        {{ 'forgot_password.email_sent_header'|trans }}
      </h1>
      <p class="text-justify">
        {{ 'forgot_password.email_sent_description'|trans({'email':email})|raw }}
      </p>
      <p class="text-center mt-5">
        <a href="{{ constant('App\\Config\\Routes::LOGIN_ROUTE_URL') }}" class="text-(--blue) hover:cursor-pointer hover:opacity-80 active:opacity-70">
          {{ 'forgot_password.back_to_login'|trans }}
        </a>
      </p>
    </div>
  {% else %}
    <div data-turbo="false">
      <h1 class="font-bold text-2xl text-center">
        {{ 'forgot_password.header'|trans }}
      </h1>
      {% if error.general is defined %}
        <div class="py-5 px-10 text-center border border-dashed border-(--red) rounded-lg bg-[#f8d7da] text-[#721c24] break-words mt-5">
          {{ error.general[0] }}
        </div>
      {% endif %}
      <twig:Form action="{{ constant('App\\Config\\Routes::FORGOT_PASSWORD_SUBMIT_ROUTE_URL') }}" method="POST" class="mt-5">
        <div>
          <twig:Input name="email" label="{{ 'forgot_password.email'|trans }}" aria-label="{{ 'forgot_password.email'|trans }}" type="text" autocomplete="email" value="{{ email }}" required error="{{ error.email is defined ? error.email[0] : '' }}" />
        </div>
        <twig:Button type="submit" variant="primary" class="my-5">
          {{ 'forgot_password.reset_password'|trans }}
        </twig:Button>
        <p class="text-center">
          <a href="{{ constant('App\\Config\\Routes::LOGIN_ROUTE_URL') }}" class="text-(--blue) hover:cursor-pointer hover:opacity-80 active:opacity-70">
            {{ 'forgot_password.back_to_login'|trans }}
          </a>
        </p>
      </twig:Form>
    </div>
  {% endif %}
{% endblock %}
