{% extends 'layouts/authentication.html.twig' %}
{% block title %}
  {{ 'register.title'|trans }}
{% endblock %}
{% set email = email | default('') %}
{% set first_name = first_name | default('') %}
{% set last_name = last_name | default('') %}
{% set middle_name = middle_name | default('') %}
{% set phone = phone | default('') %}
{% set success = success | default(false) %}
{% block auth_body %}
  {% if success %}
    <div class="flex flex-col items-center" data-turbo="false">
      <div class="w-[50px] h-[50px]">
        {{ include('icons/success.svg') }}
      </div>
      <h1 class="font-bold text-[23px] text-center my-3">
        {{ 'register.email_sent_header'|trans }}
      </h1>
      <p class="text-justify">
        {{ 'register.email_sent_description'|trans({'email':email})|raw }}
      </p>
      <p class="text-center mt-5">
        <a href="{{ constant('App\\Config\\Routes::LOGIN_ROUTE_URL') }}" class="text-(--blue) hover:cursor-pointer hover:opacity-80 active:opacity-70">
          {{ 'register.back_to_login'|trans }}
        </a>
      </p>
    </div>
  {% else %}
    <div data-turbo="false">
      <h1 class="font-bold text-2xl text-center">
        {{ 'register.header'|trans }}
      </h1>
      {% if error.general is defined %}
        <div class="py-5 px-10 text-center border border-dashed border-(--red) rounded-lg bg-[#f8d7da] text-[#721c24] break-words mt-5">
          {{ error.general[0] }}
        </div>
      {% endif %}
      <twig:Form action="{{ constant('App\\Config\\Routes::REGISTER_SUBMIT_ROUTE_URL') }}" method="POST" class="mt-5">
        <div>
          <twig:Input name="first_name" label="{{ 'register.first_name'|trans }}" aria-label="{{ 'register.first_name'|trans }}" type="text" value="{{ first_name }}" required error="{{ error.first_name is defined ? error.first_name[0] : '' }}" />
        </div>
        <div class="mt-3">
          <twig:Input name="last_name" label="{{ 'register.last_name'|trans }}" aria-label="{{ 'register.last_name'|trans }}" type="text" value="{{ last_name }}" required error="{{ error.last_name is defined ? error.last_name[0] : '' }}" />
        </div>
        <div class="mt-3">
          <twig:Input name="middle_name" label="{{ 'register.middle_name'|trans }}" aria-label="{{ 'register.middle_name'|trans }}" type="text" value="{{ middle_name }}" error="{{ error.middle_name is defined ? error.middle_name[0] : '' }}" />
        </div>
        <div class="mt-3">
          <twig:Input name="email" label="{{ 'register.email'|trans }}" aria-label="{{ 'register.email'|trans }}" type="text" autocomplete="email" value="{{ email }}" required error="{{ error.email is defined ? error.email[0] : '' }}" />
        </div>
        <div class="mt-3">
          <twig:Input name="password" label="{{ 'register.password'|trans }}" aria-label="{{ 'register.password'|trans }}" type="password" required autocomplete="off" error="{{ error.password is defined ? error.password[0] : '' }}" />
        </div>
        <div class="mt-3">
          <twig:Input name="confirm_password" label="{{ 'register.confirm_password'|trans }}" aria-label="{{ 'register.confirm_password'|trans }}" type="password" required autocomplete="off" error="{{ error.confirm_password is defined ? error.confirm_password[0] : '' }}" />
        </div>
        <twig:Button type="submit" variant="primary" class="my-5">
          {{ 'register.submit'|trans }}
        </twig:Button>
        <p class="text-center">
          <a href="{{ constant('App\\Config\\Routes::LOGIN_ROUTE_URL') }}" class="text-(--blue) hover:cursor-pointer hover:opacity-80 active:opacity-70">
            {{ 'register.back_to_login'|trans }}
          </a>
        </p>
      </twig:Form>
    </div>
  {% endif %}
{% endblock %}
