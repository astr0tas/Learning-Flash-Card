{% extends 'layouts/authentication.html.twig' %}

{% block title %}
	{{ 'verify_email.title'|trans }}
{% endblock %}

{% block auth_body %}
	{% if error.general is defined %}
		<div class="flex flex-col items-center">
			<div class="w-[50px] h-[50px] text-(--red)">
				{{include('icons/fail.svg')}}
			</div>
			<p class="text-justify mt-3">{{ error.general[0] }}</p>
			<p class="text-center mt-5">
				<a href="{{ constant('App\\Config\\Routes::LOGIN_ROUTE_URL') }}" class="text-(--blue) hover:cursor-pointer hover:opacity-80 active:opacity-70">{{ 'verify_email.back_to_login'|trans }}</a>
			</p>
		</div>
	{% else %}
		<div class="flex flex-col items-center">
			<div class="w-[50px] h-[50px]">
				{{include('icons/success.svg')}}
			</div>
			<p class="text-justify mt-3">{{'verify_email.verify_success'|trans}}</p>
			<p class="text-center mt-5">
				<a href="{{ constant('App\\Config\\Routes::LOGIN_ROUTE_URL') }}" class="text-(--blue) hover:cursor-pointer hover:opacity-80 active:opacity-70">{{ 'verify_email.back_to_login'|trans }}</a>
			</p>
		</div>
	{% endif %}
{% endblock %}
