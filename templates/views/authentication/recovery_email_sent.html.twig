{% extends 'layouts/authentication.html.twig' %}

{% block title %}
	{{ 'recovery_email_sent.title'|trans }}
{% endblock %}

{% set email = app.flashes('email') %}
{% set email = email[0] | default('') %}

{% block auth_body %}
	<div class="flex flex-col items-center">
		<div class="w-[50px] h-[50px]">
			{{include('icons/success.svg')}}
		</div>
		<h1 class="font-bold text-[23px] text-center my-3">{{ 'recovery_email_sent.header'|trans }}</h1>
		<p class="text-justify">{{'recovery_email_sent.description'|trans({'email':email})|raw}}</p>
		<p class="text-center mt-5">
			<a href="{{ constant('App\\Config\\Routes::LOGIN_ROUTE')['URL'] }}" class="text-(--blue) hover:cursor-pointer hover:opacity-80 active:opacity-70">{{ 'forgot_password.back_to_login'|trans }}</a>
		</p>
	</div>
{% endblock %}
