{% extends 'layouts/user.html.twig' %}

{% block title %}
  {{ 'card_bag.title'|trans }}
{% endblock %}

{% set card_bag_array = [] %}
{% set card_array = [] %}

{% for bag in bagList %}
  {% set bagTemplate %}
    <twig:CardBag bagId="{{ bag.id }}" bagName="{{ bag.name }}" model="selectedBags" href="{{ constant('App\\Config\\Routes::CARD_BAG_DETAIL_ROUTE_URL')|replace({'{id}': bag.id}) }}"/>
  {% endset %}

  {% set card_bag_array = card_bag_array|merge([{
    'id': bag.id,
    'name': bag.name,
    'html': bagTemplate
  }]) %}
{% endfor %}

{% for card in cardList %}
  {% set cardTemplate %}
    <twig:Card :listMode="true" cardId="{{ card.id }}" cardTitle="{{ card.title }}" cardSubtitle="{{ card.subtitle }}" cardDescription="{{ card.description }}" cardColor="{{ card.cardColor }}" cardTextColor="{{ card.cardTextColor }}" cardType="{{ card.cardType }}" model="selectedCards"/>
  {% endset %}

  {% set card_array = card_array|merge([{
    'title': card.title,
    'id': card.id,
    'subtitle': card.subtitle,
    'description': card.description,
    'color': card.cardColor,
    'textColor': card.cardTextColor,
    'type': card.cardType,
    'html': cardTemplate
  }]) %}
{% endfor %}

{% set new_bag_name = error.newBagName | default('') %}
{% set objectMovingBreadcrumb = [] %}

{% for item in breadcrumb %}
  {% set objectMovingBreadcrumb = objectMovingBreadcrumb|merge([{
    'icon': item.icon|default(null),
    'label': item.label,
    'action': "document.getElementById('moveObjectModal').dispatchEvent(new CustomEvent('set-new-parent-bag', { detail: " ~ item.id|default('null') ~ " }));",
    'id': item.id
  }]) %}
{% endfor %}

{% block javascripts %}
  {{ parent() }}
  <script>
    const objectMovingBreadcrumb = {{ objectMovingBreadcrumb|json_encode|raw }};
    const fetchBagContentUrl = "{{ constant('App\\Config\\Routes::API_USER_CARD_BAG_ROUTE_URL') }}";
    const apiRequestError = "{{ 'general_error.system_error'|trans }}";
    const bagList = {{ card_bag_array|json_encode|raw }};
    const cardList = {{ card_array|json_encode|raw }};
  </script>
  <script src="{{ asset('scripts/templates/views/user/card_bag/index.js') }}"></script>
{% endblock %}

{% block user_body %}
  <div class="flex flex-col w-full h-full gap-5" x-data="cardBag" @reset-new-bag-input.window="document.getElementById('new_bag_name').dispatchEvent(new Event('reset'))" @edit-card.window="openEditCardModal($event.detail)">
    {# Header panel #}
    <div class="flex items-center justify-between gap-2">
      {# Search bar #}
      <div class="w-full max-w-[700px]" @search="filterBagAndCard(document.getElementById('search').value)">
        <twig:Input type="search" name="search" placeholder="{{ 'card_bag.search_placeholder'|trans }}" size="9xl" @keyup.enter="filterBagAndCard(document.getElementById('search').value)"/>
      </div>
      {# Control buttons #}
      <div class="flex items-center gap-2">
        <twig:Dropdown>
          <twig:block name="dropdown_toggler">
            <twig:Button variant="primary" class="flex items-center" title="{{ 'action.create'|trans }}">
              <div class="w-5 h-5">
                {{ include('icons/plus.svg') }}
              </div>
              <div class="ms-2">
                {{ 'action.create'|trans }}
              </div>
            </twig:Button>
          </twig:block>
          <twig:block name="dropdown_content">
            <div class="py-1">
              <button class="block px-4 py-2 cursor-pointer w-full text-start" @click="document.getElementById('addNewBagModal').setAttribute('open',true)">
                {{ 'card_bag.create_options.new_bag'|trans }}
              </button>
              <button class="block px-4 py-2 cursor-pointer w-full text-start" @click="document.getElementById('addNewCardModal').setAttribute('open',true)">
                {{ 'card_bag.create_options.new_card'|trans }}
              </button>
            </div>
          </twig:block>
        </twig:Dropdown>
        <twig:Dropdown>
          <twig:block name="dropdown_toggler">
            <twig:Button variant="outline" class="flex items-center px-1!" title="{{ 'card_bag.other_option'|trans }}">
              <div class="w-5 h-5 flex items-center justify-center">
                <div class="w-3 h-3 opacity-70">
                  {{ include('icons/option.svg') }}
                </div>
              </div>
            </twig:Button>
          </twig:block>
          <twig:block name="dropdown_content">
            <div class="py-1">
              <button class="flex items-center px-4 py-2 gap-1 cursor-pointer w-full hover:text-[#101828]!" @click="document.getElementById('moveObjectModal').setAttribute('open',true)" x-bind:disabled="!selectedBags.length && !selectedCards.length" x-bind:class="!selectedBags.length && !selectedCards.length?'!hover:opacity:20 !active:opacity-25 opacity-25!':''">
                <div class="w-5 h-5 text-inherit!">
                  {{ include('icons/move_folder.svg') }}
                </div>
                <div class="ms-2 text-inherit!">
                  {{ 'action.move'|trans }}
                </div>
              </button>
              <button class="flex items-center px-4 py-2 gap-1 cursor-pointer w-full text-(--red)!" @click="document.getElementById('deleteObjectModal').setAttribute('open',true)" x-bind:disabled="!selectedBags.length && !selectedCards.length" x-bind:class="!selectedBags.length && !selectedCards.length?'!hover:opacity:20 !active:opacity-25 opacity-25!':''">
                <div class="w-5 h-5 text-inherit!">
                  {{ include('icons/trash.svg') }}
                </div>
                <div class="ms-2 text-inherit!">
                  {{ 'action.delete'|trans }}
                </div>
              </button>
            </div>
          </twig:block>
        </twig:Dropdown>
      </div>
    </div>
    {# Breadcrumb #}
    <twig:Breadcrumb :items="breadcrumb"></twig:Breadcrumb>
    {# Display body #}
    <template x-if="filteredBagList.length || filteredCardList.length">
      <div class="flex flex-col flex-1 w-full gap-10">
        {# List of bags #}
        <template x-if="filteredBagList.length">
          <div class="flex flex-col gap-5">
            <h2 class="font-medium text-xl">{{ 'card_bag.bag_list'|trans }}</h2>
            <div class="gap-4 grid grid-cols-[repeat(auto-fill,minmax(250px,1fr))]">
              <template x-for="bag in filteredBagList">
                <div class="w-full" x-html="bag.html"></div>
              </template>
            </div>
          </div>
        </template>
        <template x-if="filteredBagList.length && filteredCardList.length">
          <hr class="border-gray-300"/>
        </template>
        {# List of cards #}
        <template x-if="filteredCardList.length">
          <div class="flex flex-col gap-3">
            <h2 class="font-medium text-xl">{{ 'card_bag.card_list'|trans }}</h2>
            <div class="gap-4 grid grid-cols-[repeat(auto-fill,minmax(250px,1fr))]">
              <template x-for="(card,index) in filteredCardList">
                <div class="w-full h-75" x-bind:class="darkMode?'hover:shadow-gray-700 hover:shadow-2xl':'hover:shadow-xl'" x-html="card.html" @click="openCardDetailModal(card.id)"></div>
              </template>
            </div>
          </div>
        </template>
      </div>
    </template>
    <template x-if="!filteredBagList.length && !filteredCardList.length">
      <div class="flex-1 w-full">
        <twig:NoContent></twig:NoContent>
      </div>
    </template>
  </div>
{% endblock %}

{% block modals %}
  <twig:Modal @close="$dispatch('reset-new-bag-input')" open="{{ error.newBagError is defined }}" modalTitle="{{ 'card_bag.create_options.new_bag'|trans }}" actionButtonText="{{ 'action.add'|trans }}" actionButtonVariant="primary" @modal-action="$refs.newBagFormRef.requestSubmit();" id="addNewBagModal">
    <twig:block name="modal_body">
      <twig:Form x-ref="newBagFormRef" action="{{ constant('App\\Config\\Routes::CREATE_NEW_BAG_ROUTE_URL') }}" method="POST">
        {% if bag is defined %}
          <twig:Input hidden name="parent_bag" value="{{ bag.id }}"/>
        {% endif %}
        <div class="mb-3">
          <twig:Input type="text" name="new_bag_name" label="{{ 'card_bag.bag_name'|trans }}" aria-label="{{ 'card_bag.bag_name'|trans }}" required value="{{ new_bag_name }}" error="{{ error.newBagError is defined and error.newBagError.new_bag_name is defined ? error.newBagError.new_bag_name[0] : '' }}" maxlength="{{ constant('App\\Config\\Constraints::CARD_BAG_NAME_MAX_LENGTH') }}"/>
        </div>
      </twig:Form>
    </twig:block>
  </twig:Modal>
  <twig:Modal @close="$dispatch('reset-new-card-inputs')" open="{{ error.newCardError is defined }}" @submit-form="$refs.newCardFormRef.requestSubmit()" @close-create-new-card-modal="document.getElementById('addNewCardModal').removeAttribute('open'); setTimeout(()=>{$dispatch('close')},250)" id="addNewCardModal">
    <twig:block name="modal_content">
      <el-dialog-panel class="w-full max-w-125 h-150">
        <twig:Form x-ref="newCardFormRef" action="{{ constant('App\\Config\\Routes::CREATE_NEW_CARD_ROUTE_URL') }}" method="POST" class="flex flex-col gap-3">
          <twig:Card :createMode="true" :error="error" :bagId="bag is defined ? bag.id : null"></twig:Card>
        </twig:Form>
      </el-dialog-panel>
    </twig:block>
  </twig:Modal>
  <twig:Modal x-data="objectMove" @close="resetMoveObjectModal()" @set-new-parent-bag="newParentBag = $event.detail" @update-select-bag.window="selectedBags = $event.detail" @update-select-card.window="selectedCards = $event.detail" modalTitle="{{ 'action.move'|trans }}" @modal-action="document.getElementById('moveObjectModal').removeAttribute('open'); $refs.moveObjectFormRef.requestSubmit();" id="moveObjectModal" modalContentClass="sm:max-w-7xl!">
    <twig:block name="modal_body">
      <twig:Form x-ref="moveObjectFormRef" action="{{ constant('App\\Config\\Routes::MOVE_OBJECT_ROUTE_URL') }}" method="POST" class="hidden">
        <template x-for="selectedBag in selectedBags">
          <input type="hidden" name="bag[]" :value="selectedBag">
        </template>
        <template x-for="selectedCard in selectedCards">
          <input type="hidden" name="card[]" :value="selectedCard">
        </template>
        <input type="hidden" name="newParentBag" :value="newParentBag">
      </twig:Form>
      <div class="flex flex-col gap-10">
        <div class="flex flex-col gap-5">
          <twig:Breadcrumb :items="objectMovingBreadcrumb" id="objectMovingBreadcrumb"></twig:Breadcrumb>
          <div class="w-full" @search="searchFilter = document.getElementById('search2').value">
            <twig:Input type="search" name="search2" placeholder="{{ 'card_bag.search_placeholder2'|trans }}" size="9xl" @keyup.enter="searchFilter = document.getElementById('search2').value"/>
          </div>
        </div>
        <template x-if="filteredParentBagContent.length && !isLoading">
          <div class="flex flex-col gap-3">
            <div class="flex flex-col overflow-auto hide-browser-scollbar">
              <table>
                <thead>
                  <tr class="border-b border-gray-400 select-none">
                    <th class="text-start py-2">{{ 'card_bag.card_bag'|trans }}</th>
                    <th class="w-50 text-start py-2">{{ 'card_bag.created_at'|trans }}</th>
                  </tr>
                </thead>
                <tbody x-data="{ selectedRecord: null }" @click.window="selectedRecord = null">
                  <template x-for="(record,index) in filteredParentBagContent" :key="record.id">
                    <tr x-bind:class="{ 'border-t border-gray-400': index, 'bg-(--blue) text-(--white)': selectedRecord === index }"
                    class="cursor-pointer select-none active:opacity-80"
                    @click.window="if($el.contains($event.target)) { selectedRecord = index }"
                    @dblclick="newParentBag = record.id">
                      <td class="py-2" x-text="record.name"></td>
                      <td class="py-2" x-text="dayjs(record.createdAt).format('YYYY-MM-DD HH:mm:ss')"></td>
                    </tr>
                  </template>
                </tbody>
              </table>
            </div>
            <div class="text-(--gray) text-sm">
              *{{ 'card_bag.move_object_note'|trans }}
            </div>
          </div>
        </template>
        <template x-if="!filteredParentBagContent.length && !isLoading">
          <div class="h-[75px] w-full">
            <twig:NoContent></twig:NoContent>
          </div>
        </template>
        <twig:Loading x-show="isLoading" id="bag-content-list-loading" class="opacity-30 h-[75px]!" :displayBackdrop="false"></twig:Loading>
      </div>
    </twig:block>
    <twig:block name="action_button">
      <twig:Button type="button" class="text-sm" variant="primary" title="{{ 'action.confirm'|trans }}" @click="$dispatch('modal-action')" x-bind:disabled="originalParent === newParentBag" x-bind:class="{ 'cursor-not-allowed!' : originalParent === newParentBag }">
        {{ 'action.confirm'|trans }}
      </twig:Button>
    </twig:block>
  </twig:Modal>
  <twig:Modal x-data="{ selectedBags: [], selectedCards: [] }" @update-select-bag.window="selectedBags = $event.detail" @update-select-card.window="selectedCards = $event.detail" modalTitle="{{ 'action.delete'|trans }}" actionButtonText="{{ 'action.delete'|trans }}" actionButtonVariant="danger" @modal-action="$refs.deleteObjectFormRef.requestSubmit()" id="deleteObjectModal">
    <twig:block name="modal_body">
      <twig:Form x-ref="deleteObjectFormRef" action="{{ constant('App\\Config\\Routes::DELETE_OBJECT_ROUTE_URL') }}" method="POST" class="hidden">
        <template x-for="selectedBag in selectedBags">
          <input type="hidden" name="bag[]" :value="selectedBag">
        </template>
        <template x-for="selectedCard in selectedCards">
          <input type="hidden" name="card[]" :value="selectedCard">
        </template>
      </twig:Form>
      <div>{{ 'card_bag.delete_confirm'|trans }}</div>
    </twig:block>
  </twig:Modal>
  <twig:Modal id="cardDetailModal" @close-view-card-modal.window="$el.removeAttribute('open')">
    <twig:block name="modal_content">
      <el-dialog-panel class="w-full max-w-125 h-150">
        <twig:Card :viewMode="true"></twig:Card>
      </el-dialog-panel>
    </twig:block>
  </twig:Modal>
  <twig:Modal @close="$dispatch('set-edit-card-inputs')" open="{{ error.editCardError is defined }}" @submit-form="$refs.editCardFormRef.requestSubmit()" @close-edit-card-modal="document.getElementById('editCardModal').removeAttribute('open'); setTimeout(()=>{$dispatch('close')},250)" id="editCardModal">
    <twig:block name="modal_content">
      <el-dialog-panel class="w-full max-w-125 h-150">
        <twig:Form x-ref="editCardFormRef" action="{{ constant('App\\Config\\Routes::UPDATE_CARD_ROUTE_URL') }}" method="POST" class="flex flex-col gap-3">
          <twig:Card :editMode="true" :error="error"></twig:Card>
        </twig:Form>
      </el-dialog-panel>
    </twig:block>
  </twig:Modal>
{% endblock %}
