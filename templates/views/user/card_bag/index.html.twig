{% extends 'layouts/user.html.twig' %}

{% block title %}
	{{ 'card_bag.title'|trans }}
{% endblock %}

{% block javascripts %}
	{{parent()}}
	<script src="{{asset('scripts/templates/views/user/card_bag/index.js')}}"></script>
{% endblock %}

{% block user_body %}
	<div
		class="flex flex-col w-full h-full">
		{# Header panel #}
		<div
			class="flex items-center justify-between gap-2">
			{# Search bar #}
			<div class="w-full max-w-[700px]" @search="">
				<twig:Input type="search" name="search" placeholder="{{ 'card_bag.search_placeholder'|trans }}" size="9xl"/>
			</div>
			{# Control buttons #}
			<div class="flex items-center gap-2">
				<twig:Dropdown>
					<twig:block name="dropdown_toggler">
						<twig:Button variant="primary" class="flex items-center" title="{{'card_bag.create'|trans}}">
							<div class="w-5 h-5">{{include('icons/plus.svg')}}</div>
							<div class="ms-2">{{'card_bag.create'|trans}}</div>
						</twig:Button>
					</twig:block>
					<twig:block name="dropdown_content">
						<div class="py-1">
							<button class="block px-4 py-2 cursor-pointer w-full text-start">{{'card_bag.create_options.new_bag'|trans}}</button>
							<button class="block px-4 py-2 cursor-pointer w-full text-start">{{'card_bag.create_options.new_card'|trans}}</button>
						</div>
					</twig:block>
				</twig:Dropdown>
				<twig:Dropdown>
					<twig:block name="dropdown_toggler">
						<twig:Button variant="secondary" class="flex items-center px-1!" title="{{'card_bag.other_option'|trans}}">
							<div class="w-5 h-5 flex items-center justify-center">
								<div class="w-3 h-3 opacity-70">{{include('icons/option.svg')}}</div>
							</div>
						</twig:Button>
					</twig:block>
					<twig:block name="dropdown_content">
						<div class="py-1">
							<button class="flex items-center px-4 py-2 gap-1 cursor-pointer w-full">
								<div class="w-5 h-5">{{include('icons/move_folder.svg')}}</div>
								<div class="ms-2">{{'card_bag.move'|trans}}</div>
							</button>
							<button class="flex items-center px-4 py-2 gap-1 cursor-pointer w-full">
								<div class="w-5 h-5 text-(--red)!">{{include('icons/trash.svg')}}</div>
								<div class="ms-2 text-(--red)!">{{'card_bag.delete'|trans}}</div>
							</button>
						</div>
					</twig:block>
				</twig:Dropdown>
			</div>
		</div>
		{# Display body #}
	</div>
{% endblock %}
