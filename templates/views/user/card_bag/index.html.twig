{% extends 'layouts/user.html.twig' %}

{% block title %}
  {{ 'card_bag.title'|trans }}
{% endblock %}

{% set card_bag_array = [] %}
{% set card_array = [] %}
{% set view_card_array = [] %}

{% for bag in bagList %}
  {% set bagTemplate %}
    <twig:CardBag bagId="{{ bag.id }}" bagName="{{ bag.name }}" bagDescription="{{ bag.description }}" model="selectedBags"/>
  {% endset %}

  {% set card_bag_array = card_bag_array|merge([{
    'name': bag.name,
    'html': bagTemplate
  }]) %}
{% endfor %}

{% for card in cardList %}
  {% set cardTemplate %}
    <twig:Card cardId="{{ card.id }}" cardTitle="{{ card.title }}" cardSubTitle="{{ card.subTitle }}" cardDescription="{{ card.description }}" cardColor="{{ card.cardColor }}" cardTextColor="{{ card.cardTextColor }}" cardType="{{ card.cardType }}" model="selectedCards"/>
  {% endset %}

  {% set card_array = card_array|merge([{
    'title': card.title,
    'html': cardTemplate
  }]) %}
{% endfor %}

{% for card in cardList %}
  {% set viewCardTemplate %}
    <twig:Card :viewMode="true" cardId="{{ card.id }}" cardTitle="{{ card.title }}" cardSubTitle="{{ card.subTitle }}" cardDescription="{{ card.description }}" cardColor="{{ card.cardColor }}" cardTextColor="{{ card.cardTextColor }}" cardType="{{ card.cardType }}" model="selectedCards"/>
  {% endset %}

  {% set view_card_array = view_card_array|merge([{
    'title': card.title,
    'html': viewCardTemplate
  }]) %}
{% endfor %}

{% block javascripts %}
  {{ parent() }}
  <script>
    const bagList = {{ card_bag_array|json_encode|raw }};
    const cardList = {{ card_array|json_encode|raw }};
    const viewCardList = {{ view_card_array|json_encode|raw }};
  </script>
  <script src="{{ asset('scripts/templates/views/user/card_bag/index.js') }}"></script>
{% endblock %}

{% block user_body %}
  <div class="flex flex-col w-full h-full gap-5" x-data="cardBag" @reset-new-bag-modal.window='resetNewBagModal' @reset-new-card-modal.window="resetNewCardModal" @close-card-view-modal.window="closeCardDetailModal">
    {# Header panel #}
    <div class="flex items-center justify-between gap-2">
      {# Search bar #}
      <div class="w-full max-w-[700px]" @search="filterBagAndCard(document.getElementById('search').value)">
        <twig:Input type="search" name="search" placeholder="{{ 'card_bag.search_placeholder'|trans }}" size="9xl" />
      </div>
      {# Control buttons #}
      <div class="flex items-center gap-2">
        <twig:Dropdown>
          <twig:block name="dropdown_toggler">
            <twig:Button variant="primary" class="flex items-center" title="{{ 'action.create'|trans }}">
              <div class="w-5 h-5">
                {{ include('icons/plus.svg') }}
              </div>
              <div class="ms-2">
                {{ 'action.create'|trans }}
              </div>
            </twig:Button>
          </twig:block>
          <twig:block name="dropdown_content">
            <div class="py-1">
              <button class="block px-4 py-2 cursor-pointer w-full text-start" @click="document.getElementById('addNewBagModal').setAttribute('open',true)">
                {{ 'card_bag.create_options.new_bag'|trans }}
              </button>
              <button class="block px-4 py-2 cursor-pointer w-full text-start" @click="document.getElementById('addNewCardModal').setAttribute('open',true)">
                {{ 'card_bag.create_options.new_card'|trans }}
              </button>
            </div>
          </twig:block>
        </twig:Dropdown>
        <twig:Dropdown>
          <twig:block name="dropdown_toggler">
            <twig:Button variant="outline" class="flex items-center px-1!" title="{{ 'card_bag.other_option'|trans }}">
              <div class="w-5 h-5 flex items-center justify-center">
                <div class="w-3 h-3 opacity-70">
                  {{ include('icons/option.svg') }}
                </div>
              </div>
            </twig:Button>
          </twig:block>
          <twig:block name="dropdown_content">
            <div class="py-1">
              <button class="flex items-center px-4 py-2 gap-1 cursor-pointer w-full hover:text-[#101828]!" @click="document.getElementById('moveObjectModal').setAttribute('open',true)" x-bind:disabled="!selectedBags.length && !selectedCards.length" x-bind:class="!selectedBags.length && !selectedCards.length?'!hover:opacity:20 !active:opacity-25 opacity-25!':''">
                <div class="w-5 h-5 text-inherit!">
                  {{ include('icons/move_folder.svg') }}
                </div>
                <div class="ms-2 text-inherit!">
                  {{ 'action.move'|trans }}
                </div>
              </button>
              <button class="flex items-center px-4 py-2 gap-1 cursor-pointer w-full text-(--red)!" @click="document.getElementById('deleteObjectModal').setAttribute('open',true)" x-bind:disabled="!selectedBags.length && !selectedCards.length" x-bind:class="!selectedBags.length && !selectedCards.length?'!hover:opacity:20 !active:opacity-25 opacity-25!':''">
                <div class="w-5 h-5 text-inherit!">
                  {{ include('icons/trash.svg') }}
                </div>
                <div class="ms-2 text-inherit!">
                  {{ 'action.delete'|trans }}
                </div>
              </button>
            </div>
          </twig:block>
        </twig:Dropdown>
      </div>
    </div>
    {# Back button #}
    <div class="w-[125px]">
      <twig:Button variant="secondary" class="flex items-center gap-2" @click="if(document.referrer) { window.location.href = document.referrer; } else { history.back(); }">
        <span class="w-4 h-4">{{ include('icons/go_back.svg') }}</span>
        <span>{{ 'action.go_back'|trans }}</span>
      </twig:Button>
    </div>
    {# Display body #}
    <template x-if="filteredBagList.length || filteredCardList.length">
      <div class="flex flex-col flex-1 w-full gap-10">
        {# List of bags #}
        <template x-if="filteredBagList.length">
          <div class="flex flex-col gap-5">
            <h2 class="font-medium text-xl">{{ 'card_bag.bag_list'|trans }}</h2>
            <div class="gap-4 grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))]">
              <template x-for="bag in filteredBagList">
                <div class="w-full" x-html="bag.html"></div>
              </template>
            </div>
          </div>
        </template>
        <template x-if="filteredBagList.length && filteredCardList.length">
          <hr class="border-gray-300"/>
        </template>
        {# List of cards #}
        <template x-if="filteredCardList.length">
          <div class="flex flex-col gap-3">
            <h2 class="font-medium text-xl">{{ 'card_bag.card_list'|trans }}</h2>
            <div class="gap-4 grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))]">
              <template x-for="(card,index) in filteredCardList">
                <div class="w-full h-75" x-html="card.html" @click-on-card="openCardDetailModal(index)"></div>
              </template>
            </div>
          </div>
        </template>
      </div>
    </template>
    <template x-if="!filteredBagList.length && !filteredCardList.length">
      <div class="flex-1 w-full">
        <twig:NoContent></twig:NoContent>
      </div>
    </template>
  </div>
{% endblock %}

{% block modals %}
  <twig:Modal @close="$dispatch('reset-new-bag-modal')" open="{{ error.newBagError is defined }}" modalTitle="{{ 'card_bag.create_options.new_bag'|trans }}" actionButtonText="{{ 'action.add'|trans }}" actionButtonVariant="primary" @modal-action="$refs.newBagFormRef.submit()" id="addNewBagModal">
    <twig:block name="modal_body">
      <twig:Form x-ref="newBagFormRef" action="{{ constant('App\\Config\\Routes::CREATE_NEW_BAG_ROUTE_URL') }}" method="POST">
        {% if bag is defined %}
          <twig:Input hidden name="parent_bag" value="{{ bag.id }}"/>
        {% endif %}
        <div>
          <twig:Input type="text" name="new_bag_name" label="{{ 'card_bag.bag_name'|trans }}" aria-label="{{ 'card_bag.bag_name'|trans }}" required error="{{ error.newBagError is defined and error.newBagError.new_bag_name is defined ? error.newBagError.new_bag_name[0] : '' }}" />
        </div>
        <div class="my-3">
          <twig:Input type="textarea" name="new_bag_description" label="{{ 'card_bag.bag_description'|trans }}" aria-label="{{ 'card_bag.bag_description'|trans }}" rows="3" />
        </div>
      </twig:Form>
    </twig:block>
  </twig:Modal>
  <twig:Modal @close="$dispatch('reset-new-card-modal')" open="{{ error.newCardError is defined }}" modalTitle="{{ 'card_bag.create_options.new_card'|trans }}" actionButtonText="{{ 'action.add'|trans }}" actionButtonVariant="primary" @modal-action="$refs.newCardFormRef.submit()" id="addNewCardModal">
    <twig:block name="modal_body">
      <twig:Form x-ref="newCardFormRef" action="{{ constant('App\\Config\\Routes::CREATE_NEW_CARD_ROUTE_URL') }}" method="POST" class="flex flex-col gap-3">
        {% if bag is defined %}
          <twig:Input hidden name="bag" value="{{ bag.id }}"/>
        {% endif %}
        <div>
          <twig:Input type="text" name="title" label="{{ 'card_bag.card_title'|trans }}" aria-label="{{ 'card_bag.card_title'|trans }}" required error="{{ error.newCardError is defined and error.newCardError.title is defined ? error.newCardError.title[0] : '' }}" />
        </div>
        <div>
          <twig:Input type="text" name="sub_title" label="{{ 'card_bag.card_subtitle'|trans }}" aria-label="{{ 'card_bag.card_subtitle'|trans }}" />
        </div>
        <div>
          <twig:Select name="card_type" label="{{ 'card_bag.card_type'|trans }}" aria-label="{{ 'card_bag.card_type'|trans }}" required error="{{ error.newCardError is defined and error.newCardError.card_type is defined ? error.newCardError.card_type[0] : '' }}" default="">
            <twig:block name="options">
              <option value="" class="hidden"></option>
              {% for type in constant('App\\Config\\Constants::FLASH_CARD_BAG_TYPES') %}
                <option value="{{ type }}">{{ ('card_bag.card_type_'~(type|lower))|trans }}</option>
              {% endfor %}
            </twig:block>
          </twig:Select>
        </div>
        <div>
          <twig:Input type="textarea" name="description" label="{{ 'card_bag.card_description'|trans }}" aria-label="{{ 'card_bag.card_description'|trans }}" rows="3" />
        </div>
        <div>
          <twig:Input type="color" name="card_color" label="{{ 'card_bag.card_color'|trans }}" aria-label="{{ 'card_bag.card_color'|trans }}" value="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}" defaultValue="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_COLOR') }}"/>
        </div>
        <div>
          <twig:Input type="color" name="card_text_color" label="{{ 'card_bag.card_text_color'|trans }}" aria-label="{{ 'card_bag.card_text_color'|trans }}" value="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}" defaultValue="{{ constant('App\\Config\\Constants::FLASH_CARD_DEFAULT_TEXT_COLOR') }}"/>
        </div>
      </twig:Form>
    </twig:block>
  </twig:Modal>
  <twig:Modal modalTitle="{{ 'action.move'|trans }}" actionButtonText="{{ 'action.confirm'|trans }}" actionButtonVariant="primary" @modal-action="" id="moveObjectModal"></twig:Modal>
  <twig:Modal x-data="{ selectedBags: [], selectedCards: [] }" @update-select-bag.window="selectedBags = $event.detail" @update-select-card.window="selectedCards = $event.detail" modalTitle="{{ 'action.delete'|trans }}" actionButtonText="{{ 'action.delete'|trans }}" actionButtonVariant="danger" @modal-action="$refs.deleteObjectFormRef.submit()" id="deleteObjectModal">
    <twig:block name="modal_body">
      <twig:Form x-ref="deleteObjectFormRef" action="{{ constant('App\\Config\\Routes::DELETE_OBJECT_ROUTE_URL') }}" method="POST" class="hidden">
        <template x-for="selectedBag in selectedBags">
          <input type="hidden" name="bag[]" :value="selectedBag">
        </template>
        <template x-for="selectedCard in selectedCards">
          <input type="hidden" name="card[]" :value="selectedCard">
        </template>
      </twig:Form>
      <div>{{ 'card_bag.delete_confirm'|trans }}</div>
    </twig:block>
  </twig:Modal>
  <twig:Modal x-data="{ selectedCard: '' }" id="card_detail_modal" @close="$dispatch('close-card-view-modal')">
    {% block modal_content %}
      <el-dialog-panel class="max-w-125 h-150" x-html="selectedCard" @set-selected-card-data.window="selectedCard = $event.detail.html" @edit-card="openEditCardModal(index)"></el-dialog-panel>
    {% endblock %}
  </twig:Modal>
{% endblock %}
